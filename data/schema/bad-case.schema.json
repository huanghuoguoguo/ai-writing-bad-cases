{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/huanghuoguoguo/ai-writing-bad-cases/blob/main/data/schema/bad-case.schema.json",
  "title": "BadCaseRecord",
  "type": "object",
  "required": [
    "id",
    "lang",
    "genres",
    "label",
    "severity",
    "diagnostic_dimensions",
    "description",
    "matchers",
    "rewrite_hint"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+$"
    },
    "lang": {
      "type": "string"
    },
    "genres": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "label": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "severity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "diagnostic_dimensions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "description": {
      "type": "string"
    },
    "why_it_sounds_ai": {
      "type": "string"
    },
    "matchers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "pattern"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "phrase",
              "substring",
              "regex",
              "keyword_set"
            ]
          },
          "pattern": {
            "type": "string"
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "flags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "counter_examples": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rewrite_hint": {
      "type": "string"
    },
    "prompt_rule": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
